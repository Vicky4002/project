# --- Supabase Postgres ---
# Pooled URL (recommended for app runtime, PgBouncer port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Direct URL (recommended for migrations/admin tasks, direct port 5432)
DIRECT_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# Optional split credentials if not embedding credentials in DATABASE_URL
SUPABASE_DB_URL=jdbc:postgresql://localhost:5432/turfhub
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=YOUR_PASSWORD

# Backend pool tuning
DB_POOL_SIZE=10
DB_MIN_IDLE=2

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Frontend runtime/build vars
VITE_API_BASE_URL=http://localhost:8080/api
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
